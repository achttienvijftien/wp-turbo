{
    "name": "achttienvijftien/wp-turbo",
    "description": "Symfony UX Turbo for WordPress: the installable mu-plugin carrying the frontend (JS runtime, asset enqueue) on top of achttienvijftien/wp-turbo-bundle",
    "type": "wordpress-muplugin",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "1815",
            "email": "it@1815.nl"
        }
    ],
    "require": {
        "php": "^8.3",
        "achttienvijftien/wp-turbo-bundle": "@dev",
        "composer/installers": "^1.8 || ^2.0"
    },
    "scripts": {
        "format": "phpcbf --report-summary --report-source",
        "lint": "phpcs"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "achttienvijftien/building-techniques": "^1.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.2",
        "phpcompatibility/phpcompatibility-wp": "*"
    },
    "autoload": {
        "psr-4": {
            "AchttienVijftien\\Plugin\\WpTurbo\\": "src/"
        }
    }
}
